{% set common_settings = sulu_snippet_load_by_area('common_settings') %}
{% set global_best_quality = (common_settings and common_settings.content.force_best_quality is defined) ? common_settings.content.force_best_quality : false %}
<!DOCTYPE html>
<html lang="{{ app.request.locale|split('_')[0] }}">
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <link rel="icon" href="{{ asset('favicon.ico') }}" sizes="32x32">
    <link rel="icon" href="{{ asset('favicon.svg') }}" type="image/svg+xml">
    <link rel="apple-touch-icon" href="{{ asset('apple-touch-icon.png') }}">

    <link href="https://fonts.googleapis.com" rel="preconnect"/>
    <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect"/>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&amp;family=Lexend:wght@400;500;600;700&amp;family=Material+Icons+Outlined&amp;display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <script src="https://cdn.tailwindcss.com?plugins=forms,typography,container-queries"></script>
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        primary: "#3B82F6",
                        navy: "#0F172A",
                        "background-light": "#F8FAFC",
                        "background-dark": "#0F172A",
                    },
                    fontFamily: {
                        display: ["Lexend", "sans-serif"],
                        sans: ["Inter", "sans-serif"],
                    },
                    borderRadius: {
                        DEFAULT: "0.75rem",
                    },
                },
            },
            plugins: [
                function({ addUtilities }) {
                    addUtilities({
                        '.overflow-wrap-anywhere': {
                            'overflow-wrap': 'anywhere',
                            'word-break': 'break-word',
                        },
                        '.no-scrollbar': {
                            '-ms-overflow-style': 'none',
                            'scrollbar-width': 'none',
                            '&::-webkit-scrollbar': {
                                'display': 'none',
                            },
                        },
                    })
                },
            ],
        };
    </script>
    <style type="text/tailwindcss">
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            vertical-align: middle;
            line-height: 1;
        }
        @layer base {
            html {
                -webkit-tap-highlight-color: transparent;
                scroll-behavior: smooth;
            }
            body {
                @apply break-words overflow-x-hidden;
                hyphens: auto;
                -webkit-hyphens: auto;
                -moz-hyphens: auto;
                width: 100%;
                min-width: 0;
            }
            h1, h2, h3, h4, h5, h6 {
                @apply overflow-wrap-anywhere;
                hyphens: auto;
                -webkit-hyphens: auto;
                -moz-hyphens: auto;
                word-break: break-word;
                overflow-wrap: anywhere;
            }
        }

        #contact{
            a{
                color: #000000;
            }
        }
    </style>

    {% block meta %}
        {{ include('@SuluWebsite/Extension/seo.html.twig', {
            seo: extension.seo|default([]),
            content: content|default([]),
            localizations: localizations|default([]),
            shadowBaseLocale: shadowBaseLocale|default(),
        }) }}
    {% endblock %}

    {% block style %}
        {{ encore_entry_link_tags('app', null, 'website') }}
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css">
    {% endblock %}
</head>
<body class="bg-background-light dark:bg-background-dark text-slate-900 dark:text-slate-100 font-sans transition-colors duration-300">
    {% include 'includes/header.html.twig' %}

    <!-- Mobile Menu Backdrop -->
    <div class="fixed inset-0 z-[99998] bg-slate-900/50 backdrop-blur-sm" id="mobile-menu-backdrop" style="display: none !important;"></div>

    <!-- Mobile Menu Drawer -->
    <div class="fixed inset-y-0 right-0 z-[99999] w-full md:max-w-md bg-white dark:bg-slate-900 shadow-2xl" id="mobile-menu" style="display: none !important;">
        <div class="flex flex-col h-full relative">
            {% set footerSettings = sulu_snippet_load_by_area('footer_settings') %}
            {% set headerSettings = sulu_snippet_load_by_area('header_settings') %}
            {% set addressSettings = sulu_snippet_load_by_area('address_settings') %}
            {% set booking_url = sulu_content_path('/contact') %}
            {% if headerSettings and headerSettings.content.booking_button_link is defined and headerSettings.content.booking_button_link is not empty %}
                {% set booking_url = sulu_content_path(headerSettings.content.booking_button_link|first.url) %}
            {% endif %}

            <div class="p-6 h-full flex flex-col overflow-y-auto">
                <div class="flex justify-between items-center mb-10 border-b pb-6">
                    <a href="{{ sulu_content_root_path() }}" class="flex items-center gap-2">
                        {% if common_settings and common_settings.content.logo is defined and common_settings.content.logo|length > 0 %}
                            {% set image = common_settings.content.logo %}
                            <img src="{{ image.thumbnails['sulu-400x400-inset']|default(image.url) }}" alt="{{ common_settings.content.company_name|default('') }}" class="h-10 w-auto">
                        {% else %}
                            <div class="bg-primary p-2 rounded-lg">
                                {% set icon = 'medical_services' %}
                                {% if headerSettings and headerSettings.content.logo_icon is defined and headerSettings.content.logo_icon is not empty %}
                                    {% set icon = headerSettings.content.logo_icon %}
                                {% endif %}
                                <span class="material-symbols-outlined text-white">{{ icon }}</span>
                            </div>
                        {% endif %}
                        <span class="font-display font-bold text-xl sm:text-2xl tracking-tight text-slate-900 dark:text-white">{{ common_settings.content.company_name|default('OralCare') }}<span class="text-primary">.</span></span>
                    </a>
                    <button class="p-2 rounded-full hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors" id="mobile-menu-close">
                        <span class="material-symbols-outlined">close</span>
                    </button>
                </div>

                <nav class="flex flex-col space-y-6 mb-10">
                    <a class="text-2xl font-bold text-slate-900 dark:text-white hover:text-primary transition-colors {{ app.request.pathInfo == sulu_content_root_path() ? 'text-primary' : '' }}" href="{{ sulu_content_root_path() }}">
                        {{ headerSettings.content.home_link_title|default('Home'|trans) }}
                    </a>
                    {% set navItems = sulu_page_navigation_root_tree('main', 1) %}
                    {% for item in navItems %}
                        <a class="text-2xl font-bold text-slate-900 dark:text-white hover:text-primary transition-colors {{ app.request.pathInfo == sulu_content_path(item.url) ? 'text-primary' : '' }}" href="{{ sulu_content_path(item.url) }}">
                            {{ item.title }}
                        </a>
                    {% endfor %}
                </nav>

                <div class="mt-auto pt-8 border-t border-slate-200 dark:border-slate-800">
                    {% if addressSettings and addressSettings.content.phone is defined and addressSettings.content.phone %}
                        <a class="flex items-center gap-3 text-slate-600 dark:text-slate-300 font-medium mb-6 text-lg" href="tel:{{ addressSettings.content.phone|replace({' ': ''}) }}">
                            <span class="material-symbols-outlined text-primary text-2xl">call</span>
                            {{ addressSettings.content.phone }}
                        </a>
                    {% endif %}
                    <a href="{{ booking_url }}" class="block w-full text-center bg-primary hover:bg-blue-600 text-white px-6 py-4 rounded-full font-bold text-xl transition-all shadow-lg shadow-blue-500/25">
                        {{ headerSettings.content.booking_button_text|default('Termin buchen'|trans) }}
                    </a>
                </div>
            </div>
        </div>
    </div>

    <main class="w-full max-w-full overflow-hidden">
        {% block content %}{% endblock %}
    </main>

    {% include 'includes/footer.html.twig' %}

    <script>
        const themeToggle = document.getElementById('theme-toggle');
        const html = document.documentElement;
        // Check for saved theme
        if (localStorage.theme === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            html.classList.add('dark');
        } else {
            html.classList.remove('dark');
        }
        if (themeToggle) {
            themeToggle.addEventListener('click', () => {
                if (html.classList.contains('dark')) {
                    html.classList.remove('dark');
                    localStorage.theme = 'light';
                } else {
                    html.classList.add('dark');
                    localStorage.theme = 'dark';
                }
            });
        }

        const mobileMenuToggle = document.getElementById('mobile-menu-toggle');
        const mobileMenuClose = document.getElementById('mobile-menu-close');
        const mobileMenuBackdrop = document.getElementById('mobile-menu-backdrop');
        const mobileMenu = document.getElementById('mobile-menu');

        const closeMenu = () => {
            if (mobileMenu) mobileMenu.style.setProperty('display', 'none', 'important');
            if (mobileMenuBackdrop) mobileMenuBackdrop.style.setProperty('display', 'none', 'important');
            document.body.style.overflow = '';
        };

        if (mobileMenuToggle && mobileMenu) {
            mobileMenuToggle.addEventListener('click', () => {
                // Ensure no conflicting hidden class
                mobileMenu.classList.remove('hidden');
                if (mobileMenuBackdrop) mobileMenuBackdrop.classList.remove('hidden');

                // Force visibility with inline style
                mobileMenu.style.setProperty('display', 'block', 'important');
                if (mobileMenuBackdrop) mobileMenuBackdrop.style.setProperty('display', 'block', 'important');

                document.body.style.overflow = 'hidden';
            });
        }

        if (mobileMenuClose) {
            mobileMenuClose.addEventListener('click', closeMenu);
        }

        if (mobileMenuBackdrop) {
            mobileMenuBackdrop.addEventListener('click', closeMenu);
        }
    </script>

    {% block javascripts %}{% endblock %}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    {{ encore_entry_script_tags('app') }}
</body>
</html>
