{% extends 'base.html.twig' %}

{% block content %}

    {% set common_settings = sulu_snippet_load_by_area('common_settings') %}
    {% set global_best_quality = common_settings.content.force_best_quality|default(false) %}
    {# Hero Section #}
    <header class="relative pt-16 pb-20 overflow-hidden w-full max-w-full overflow-x-hidden">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 w-full">
            <div class="max-w-3xl min-w-0 flex flex-col overflow-hidden">
                {% if content.hero_badge is not empty %}
                    <span class="inline-block py-1 px-3 rounded-full bg-blue-100 dark:bg-blue-900/30 text-primary text-sm font-semibold mb-4 w-fit">
                        {{ content.hero_badge }}
                    </span>
                {% endif %}
                <h1 class="text-5xl md:text-6xl font-bold mb-6 tracking-tight leading-snug text-slate-900 dark:text-white break-words hyphens-auto min-w-0 w-full max-w-full">
                    {{ content.title|raw }}
                </h1>
                {% if content.hero_subtitle is not empty %}
                    <p class="text-xl text-slate-600 dark:text-slate-400 leading-relaxed max-w-2xl break-words">
                        {{ content.hero_subtitle|raw }}
                    </p>
                {% endif %}
            </div>
        </div>
        <div class="absolute top-0 right-0 -translate-y-1/2 translate-x-1/4 w-[600px] h-[600px] bg-primary/5 rounded-full blur-3xl -z-10"></div>
    </header>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-24">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-24">
            {% for service in content.services_list %}
                <article class="group flex flex-col bg-white dark:bg-gray-800 rounded-3xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 border border-gray-100 dark:border-gray-700">
                    <div class="h-64 overflow-hidden">
                        {% if service.image is not empty or service.image_mobile is not empty %}
                            {% set image = service.image|first %}
                            {% set image_mobile = service.image_mobile|first|default(image) %}
                            {% set variant = service.variant|default('square') %}
                            {% set mobile_variant = service.mobile_variant|default('square') %}

                            {% set quality = service.quality|default(global_best_quality ? 'best' : 'standard') %}
                            {% set mobile_quality = service.mobile_quality|default(global_best_quality ? 'best' : 'standard') %}
                            {% if quality == 'best' %}
                                {% set desktop_format = variant ~ '-xl' %}
                            {% else %}
                                {% set desktop_format = variant ~ '-lg' %}
                            {% endif %}
                            {% if mobile_quality == 'best' %}
                                {% set mobile_format = mobile_variant ~ '-xl' %}
                            {% else %}
                                {% set mobile_format = mobile_variant ~ '-md' %}
                            {% endif %}

                            <picture>
                                <source media="(max-width: 639px)" srcset="{{ image_mobile.thumbnails[mobile_format]|default(image_mobile.url) }}">
                                <img src="{{ image.thumbnails[desktop_format]|default(image.thumbnails['square-md'])|default(image.url) }}"
                                     alt="{{ service.title }}"
                                     class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                                     style="object-position: {{ image.focusX|default(50) }}% {{ image.focusY|default(50) }}%">
                            </picture>
                        {% else %}
                            <img alt="{{ service.title }}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" src="https://images.unsplash.com/photo-1588776814546-1ffcf47267a5?q=80&w=800&auto=format&fit=crop">
                        {% endif %}
                    </div>
                    <div class="p-8">
                        <div class="flex items-center gap-3 mb-4">
                            <div class="w-10 h-10 rounded-lg bg-blue-50 dark:bg-blue-900/20 flex items-center justify-center text-primary p-2">
                                {% if service.icon is not empty %}
                                    {% set icon = service.icon|first %}
                                    <img src="{{ icon.url }}" alt="{{ icon.title }}" class="w-full h-full object-contain dark:invert">
                                {% else %}
                                    <span class="material-symbols-outlined text-primary">verified</span>
                                {% endif %}
                            </div>
                            <h2 class="text-2xl font-bold text-slate-900 dark:text-white">{{ service.title }}</h2>
                        </div>
                        <p class="text-slate-600 dark:text-slate-400 mb-6 leading-relaxed">
                            {{ service.description|raw }}
                        </p>
                        {% if service.link is not empty %}
                            <a class="inline-flex items-center font-semibold text-primary group-hover:gap-2 transition-all" href="{{ sulu_content_path(service.link|first.url) }}">
                                {{ 'Mehr erfahren'|trans }} <span class="material-symbols-outlined text-sm ml-1">arrow_forward</span>
                            </a>
                        {% endif %}
                    </div>
                </article>
            {% endfor %}
        </div>

        {# CTA Section #}
        {% if content.cta_title is not empty or content.cta_subtitle is not empty %}
            <section class="mt-32 relative rounded-3xl overflow-hidden bg-primary px-8 py-16 text-center text-white">
                <div class="relative z-10 max-w-2xl mx-auto">
                    <h2 class="text-3xl md:text-4xl font-bold mb-4">{{ content.cta_title|default('Bereit zu buchen?'|trans) }}</h2>
                    {% if content.cta_subtitle is not empty %}
                        <p class="text-blue-100 text-lg mb-10">
                            {{ content.cta_subtitle|raw }}
                        </p>
                    {% endif %}
                    {% if content.cta_button_link is not empty %}
                        <a href="{{ sulu_content_path(content.cta_button_link|first.url) }}" class="bg-white text-primary px-10 py-4 rounded-xl font-bold text-lg hover:bg-blue-50 transition-colors shadow-lg inline-block">
                            {{ content.cta_button_text|default('Termin jetzt buchen'|trans) }}
                        </a>
                    {% endif %}
                </div>
                <div class="absolute top-0 right-0 p-8 opacity-10">
                    <span class="material-symbols-outlined text-[12rem]">calendar_month</span>
                </div>
                <div class="absolute bottom-0 left-0 p-8 opacity-10">
                    <span class="material-symbols-outlined text-[8rem]">verified</span>
                </div>
            </section>
        {% endif %}
    </main>
{% endblock %}
