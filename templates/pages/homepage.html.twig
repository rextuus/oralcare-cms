{% extends 'base.html.twig' %}

{% block content %}

    {% set common_settings = sulu_snippet_load_by_area('common_settings') %}
    {% set global_best_quality = common_settings.content.force_best_quality|default(false) %}

    {% set footerSettings = sulu_snippet_load_by_area('footer_settings') %}
    {% set addressSettings = sulu_snippet_load_by_area('address_settings') %}

    {# Hero Section #}
    <section class="relative pt-16 pb-20 lg:pt-32 lg:pb-32 bg-slate-50 dark:bg-slate-900/50 flex flex-col items-center w-full max-w-full overflow-x-hidden">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 w-full flex flex-col items-center">
            <div class="flex flex-col lg:flex-row gap-8 lg:gap-12 items-center w-full min-w-0 max-w-full">
                <div class="space-y-8 animate-in fade-in slide-in-from-left-8 duration-700 min-w-0 w-full flex flex-col max-w-full lg:flex-1 overflow-hidden">
                    <div>
                        {% if content.hero_badge is not empty %}
                            <span class="inline-block py-1 px-4 rounded-full bg-blue-100 dark:bg-blue-900/30 text-primary font-semibold text-sm mb-4 w-fit">
                                {{ content.hero_badge }}
                            </span>
                        {% endif %}
                        <h1 class="text-4xl sm:text-5xl lg:text-7xl font-display font-bold text-slate-900 dark:text-white leading-[1.1] break-words hyphens-auto min-w-0 w-full max-w-full overflow-hidden">
                            {{ content.title|raw }}
                        </h1>
                        {% if content.hero_subtitle is not empty %}
                            <p class="mt-6 text-lg text-slate-600 dark:text-slate-400 max-w-xl leading-relaxed break-words overflow-hidden">
                                {{ content.hero_subtitle|raw }}
                            </p>
                        {% endif %}
                    </div>
                    <div class="flex flex-col sm:flex-row gap-4">
                        <a href="{{ sulu_content_path('/contact') }}" class="bg-primary hover:bg-blue-600 text-white px-8 py-4 rounded-xl font-bold text-lg transition-all shadow-xl shadow-blue-500/30 flex items-center justify-center gap-2">
                            {{ 'Termin online buchen'|trans }}
                            <span class="material-symbols-outlined">calendar_today</span>
                        </a>
                        <a href="#services" class="bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 hover:bg-slate-50 dark:hover:bg-slate-700 text-slate-900 dark:text-white px-8 py-4 rounded-xl font-bold text-lg transition-all flex items-center justify-center gap-2">
                            {{ 'Leistungen ansehen'|trans }}
                        </a>
                    </div>
                </div>
                <div class="relative animate-in fade-in zoom-in duration-1000 w-full max-w-[500px] mx-auto lg:max-w-none min-w-0 flex flex-col items-center max-w-full lg:flex-1">
                    <div class="absolute -top-6 -left-6 w-24 h-24 bg-blue-100 dark:bg-blue-900/20 rounded-full blur-2xl -z-10"></div>
                    <div class="absolute -bottom-10 -right-10 w-40 h-40 bg-primary/20 rounded-full blur-3xl -z-10"></div>
                    <div class="relative rounded-[2.5rem] shadow-2xl shadow-blue-900/20 w-full max-w-full">
                        <div class="rounded-[2.5rem] overflow-hidden">
                            {% if content.hero_image is not empty or content.hero_image_mobile is not empty %}
                                {% set image = content.hero_image|first %}
                                {% set image_mobile = content.hero_image_mobile|first|default(image) %}
                                {% set variant = content.hero_image_variant|default('vertical') %}
                                {% set mobile_variant = content.hero_image_mobile_variant|default('vertical') %}

                                {% set default_quality = global_best_quality ? 'best' : 'standard' %}

                                {% set quality = content.hero_image_quality|default(default_quality, true) %}
                                {% set mobile_quality = content.hero_image_mobile_quality|default(default_quality, true) %}
                                {% if quality == 'best' %}
                                    {% set desktop_format = variant ~ '-xl' %}
                                {% else %}
                                    {% set desktop_format = variant ~ '-lg' %}
                                {% endif %}
                                {% if mobile_quality == 'best' %}
                                    {% set mobile_format = mobile_variant ~ '-xl' %}
                                {% else %}
                                    {% set mobile_format = mobile_variant ~ '-md' %}
                                {% endif %}

                                <picture>
                                    <source media="(max-width: 639px)" srcset="{{ image_mobile.thumbnails[mobile_format]|default(image_mobile.url) }}">
                                    <img src="{{ image.thumbnails[desktop_format]|default(image.thumbnails['vertical-lg'])|default(image.url) }}"
                                         alt="{{ image.title }}"
                                         class="w-full h-[300px] sm:h-[400px] lg:h-[600px] {{ variant == 'horizontal' ? 'lg:h-[400px]' : '' }} object-cover max-w-full block"
                                         style="object-position: {{ image.focusX|default(50) }}% {{ image.focusY|default(50) }}%">
                                </picture>
                            {% else %}
                                <img alt="Smiling male dentist in a modern office" class="w-full h-[300px] sm:h-[400px] lg:h-[600px] object-cover max-w-full block" src="https://images.unsplash.com/photo-1622253692010-333f2da6031d?q=80&w=1964&auto=format&fit=crop">
                            {% endif %}
                        </div>
                        {% if content.hero_avail_title is not empty or content.hero_avail_text is not empty %}
                            <div class="absolute bottom-6 left-4 right-4 sm:left-8 sm:right-8 bg-white/90 dark:bg-slate-900/90 backdrop-blur p-4 sm:p-6 rounded-2xl shadow-xl flex items-center gap-4 border border-white/20 z-10">
                                <div class="bg-green-100 dark:bg-green-900/30 p-2 sm:p-3 rounded-full flex-shrink-0">
                                    <span class="material-symbols-outlined text-green-600 dark:text-green-400">verified</span>
                                </div>
                                <div>
                                    <p class="text-xs sm:text-sm font-semibold text-slate-900 dark:text-white">
                                        {{ content.hero_avail_title|default('Nächster freier Termin'|trans) }}
                                    </p>
                                    <p class="text-sm sm:text-base text-primary font-bold">
                                        {{ content.hero_avail_text|default('Heute, 14:30 Uhr'|trans) }}
                                    </p>
                                </div>
                            </div>
                        {% else %}
                            <div class="absolute bottom-6 left-4 right-4 sm:left-8 sm:right-8 bg-white/90 dark:bg-slate-900/90 backdrop-blur p-4 sm:p-6 rounded-2xl shadow-xl flex items-center gap-4 border border-white/20 z-10">
                                <div class="bg-green-100 dark:bg-green-900/30 p-2 sm:p-3 rounded-full flex-shrink-0">
                                    <span class="material-symbols-outlined text-green-600 dark:text-green-400">verified</span>
                                </div>
                                <div>
                                    <p class="text-xs sm:text-sm font-semibold text-slate-900 dark:text-white">{{ 'Nächster freier Termin'|trans }}</p>
                                    <p class="text-sm sm:text-base text-primary font-bold">{{ 'Heute, 14:30 Uhr'|trans }}</p>
                                </div>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </section>

    {# About Section #}
    <section class="py-24 bg-white dark:bg-slate-900 transition-colors overflow-hidden" id="about">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid lg:grid-cols-2 gap-16 items-center">
                <div class="grid grid-cols-2 gap-4 overflow-hidden">
                    {% if content.about_images is not empty %}
                        {% for block in content.about_images %}
                            {% if block.image is not empty or block.image_mobile is not empty %}
                                {% set image = block.image|first %}
                                {% set image_mobile = block.image_mobile|first|default(image) %}
                                {% set variant = block.variant|default('square') %}
                                {% set mobile_variant = block.mobile_variant|default('square') %}

                                {% set quality = block.quality|default(global_best_quality ? 'best' : 'standard') %}
                                {% set mobile_quality = block.mobile_quality|default(global_best_quality ? 'best' : 'standard') %}
                                {% if quality == 'best' %}
                                    {% set desktop_format = variant ~ '-xl' %}
                                {% else %}
                                    {% set desktop_format = variant ~ '-lg' %}
                                {% endif %}
                                {% if mobile_quality == 'best' %}
                                    {% set mobile_format = mobile_variant ~ '-xl' %}
                                {% else %}
                                    {% set mobile_format = mobile_variant ~ '-md' %}
                                {% endif %}

                                <picture>
                                    <source media="(max-width: 639px)" srcset="{{ image_mobile.thumbnails[mobile_format]|default(image_mobile.url) }}">
                                    <img src="{{ image.thumbnails[desktop_format]|default(image.thumbnails['square-md'])|default(image.url) }}"
                                         alt="{{ image.title }}"
                                         class="rounded-3xl {{ variant == 'horizontal' ? 'h-48' : (variant == 'vertical' ? 'h-80' : 'h-64') }} w-full object-cover shadow-lg {{ loop.index0 % 2 == 0 ? (loop.index0 == 0 ? 'mt-8' : '') : (loop.index0 == 3 ? '-mt-8' : '') }} block max-w-full"
                                         style="object-position: {{ image.focusX|default(50) }}% {{ image.focusY|default(50) }}%">
                                </picture>
                            {% endif %}
                        {% endfor %}
                    {% else %}
                        <img alt="Dental examination chair" class="rounded-3xl h-64 w-full object-cover shadow-lg mt-8 block max-w-full" src="https://images.unsplash.com/photo-1629909608135-ca29ed974bb9?q=80&w=2047&auto=format&fit=crop">
                        <img alt="Modern dental equipment" class="rounded-3xl h-64 w-full object-cover shadow-lg block max-w-full" src="https://images.unsplash.com/photo-1588776814546-1ffcf47267a5?q=80&w=2070&auto=format&fit=crop">
                        <img alt="Sterile tools" class="rounded-3xl h-64 w-full object-cover shadow-lg block max-w-full" src="https://images.unsplash.com/photo-1597764690523-15bea4c581c9?q=80&w=2070&auto=format&fit=crop">
                        <img alt="Patient consultation" class="rounded-3xl h-64 w-full object-cover shadow-lg -mt-8 block max-w-full" src="https://images.unsplash.com/photo-1606811841689-23dfddce3e95?q=80&w=1974&auto=format&fit=crop">
                    {% endif %}
                </div>
                <div class="space-y-6 min-w-0 overflow-hidden">
                    <div class="inline-flex items-center gap-2 text-primary font-bold tracking-wider uppercase text-sm">
                        <span class="w-8 h-px bg-primary"></span>
                        {{ content.about_badge|default('Über die Praxis'|trans) }}
                    </div>
                    <h2 class="text-3xl sm:text-4xl font-display font-bold text-slate-900 dark:text-white break-words">{{ content.about_title|default('Fachkompetente Betreuung für jeden Patienten'|trans) }}</h2>
                    {% if content.about_description_1 is not empty %}
                        <div class="text-lg text-slate-600 dark:text-slate-400 leading-relaxed break-words overflow-hidden">
                            {{ content.about_description_1|raw }}
                        </div>
                    {% endif %}
                    {% if content.about_description_2 is not empty %}
                        <div class="text-lg text-slate-600 dark:text-slate-400 leading-relaxed break-words overflow-hidden">
                            {{ content.about_description_2|raw }}
                        </div>
                    {% endif %}

                    {% if content.about_features is not empty %}
                        <div class="grid grid-cols-2 gap-6 pt-4">
                            {% for feature in content.about_features %}
                                <div class="flex items-start gap-3 min-w-0">
                                    <div class="w-10 h-10 bg-blue-100 dark:bg-blue-900/30 rounded-lg flex items-center justify-center flex-shrink-0 p-2">
                                        {% if feature.icon is not empty %}
                                            {% set icon = feature.icon|first %}
                                            <img src="{{ icon.url }}" alt="{{ icon.title }}" class="w-full h-full object-contain dark:invert">
                                        {% else %}
                                            <span class="material-symbols-outlined text-primary text-xl">verified</span>
                                        {% endif %}
                                    </div>
                                    <div class="min-w-0">
                                        <h4 class="font-bold text-slate-900 dark:text-white truncate">{{ feature.title }}</h4>
                                        <p class="text-sm text-slate-500 truncate">{{ feature.subtitle }}</p>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </section>

    {# Services Section #}
    <section class="py-24 bg-background-light dark:bg-slate-900/50 overflow-hidden" id="services">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center mb-12 sm:mb-16 min-w-0">
            <h2 class="text-3xl sm:text-4xl font-display font-bold text-slate-900 dark:text-white mb-4 break-words">{{ content.services_title|default('Unsere Kernleistungen'|trans) }}</h2>
            {% if content.services_subtitle is not empty %}
                <div class="text-slate-600 dark:text-slate-400 max-w-2xl mx-auto text-lg break-words overflow-hidden">
                    {{ content.services_subtitle|raw }}
                </div>
            {% endif %}
        </div>

        {% set use_carousel = content.services_carousel_enable|default(false) %}
        {% set carousel_height = content.services_carousel_height|default('large') %}
        {% set height_class = 'h-[500px] sm:h-[600px]' %}
        {% set width_class = 'max-w-7xl' %}
        {% if carousel_height == 'small' %}
            {% set height_class = 'h-[300px] sm:h-[400px]' %}
            {% set width_class = 'max-w-4xl' %}
        {% elseif carousel_height == 'medium' %}
            {% set height_class = 'h-[400px] sm:h-[500px]' %}
            {% set width_class = 'max-w-5xl' %}
        {% endif %}

        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            {% if use_carousel %}
                {% set services = content.services_selection is not empty ? content.services_selection : content.services_list %}
                {% set seconds = content.services_carousel_autoplay_seconds|default(0) %}
                {% set interval = seconds > 0 ? seconds * 1000 : 'false' %}

                <div id="servicesBootstrapCarousel" class="carousel slide" data-bs-ride="{{ seconds > 0 ? 'carousel' : 'false' }}" data-bs-interval="{{ interval }}">
                    <!-- Indicators -->
                    <div class="carousel-indicators relative mt-8">
                        {% for i in 0..(services|length - 1) %}
                            <button type="button" data-bs-target="#servicesBootstrapCarousel" data-bs-slide-to="{{ i }}" class="{{ loop.first ? 'active' : '' }} bg-primary" aria-current="{{ loop.first ? 'true' : 'false' }}" aria-label="Slide {{ i + 1 }}"></button>
                        {% endfor %}
                    </div>

                    <div class="carousel-inner">
                        {% for service in services %}
                            <div class="carousel-item {{ loop.first ? 'active' : '' }}">
                                <div class="px-md-5">
                                    <div class="{{ height_class }} {{ width_class }} mx-auto">
                                        {{ _self.render_service_card(service, content.services_selection is not empty) }}
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>

                    {% if content.services_carousel_show_nav|default(false) %}
                        <!-- Controls -->
                        <button class="carousel-control-prev !left-[-5%] !w-[5%] !opacity-100 hidden lg:flex" type="button" data-bs-target="#servicesBootstrapCarousel" data-bs-slide="prev">
                            <span class="flex w-12 h-12 rounded-full bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 items-center justify-center shadow-lg hover:bg-slate-50 dark:hover:bg-slate-700 transition-colors text-slate-900 dark:text-white">
                                <span class="material-symbols-outlined">chevron_left</span>
                            </span>
                        </button>
                        <button class="carousel-control-next !right-[-5%] !w-[5%] !opacity-100 hidden lg:flex" type="button" data-bs-target="#servicesBootstrapCarousel" data-bs-slide="next">
                            <span class="flex w-12 h-12 rounded-full bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 items-center justify-center shadow-lg hover:bg-slate-50 dark:hover:bg-slate-700 transition-colors text-slate-900 dark:text-white">
                                <span class="material-symbols-outlined">chevron_right</span>
                            </span>
                        </button>
                    {% endif %}
                </div>
            {% else %}
                <div class="grid md:grid-cols-2 {{ carousel_height == 'small' ? 'lg:grid-cols-4' : 'lg:grid-cols-3' }} gap-8 min-w-0">
                    {% set services = content.services_selection is not empty ? content.services_selection : content.services_list %}
                    {% for service in services %}
                        <div class="{{ height_class }}">
                            {{ _self.render_service_card(service, content.services_selection is not empty) }}
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </div>

        <style>
            .carousel-indicators [data-bs-target] {
                width: 12px;
                height: 12px;
                border-radius: 50%;
                margin: 0 5px;
            }
            #servicesBootstrapCarousel .carousel-item {
                transition: transform 0.6s ease-in-out;
            }
        </style>
    </section>

    {# Card partial to avoid repetition #}
    {% macro render_service_card(service, is_page) %}
        {% set image = null %}
        {% set image_mobile = null %}
        {% set variant = 'landscape' %}
        {% set mobile_variant = 'landscape' %}

        {% if is_page %}
            {% if service.excerpt.images is defined and service.excerpt.images is not empty %}
                {% set image = service.excerpt.images|first %}
                {% set image_mobile = image %}
            {% endif %}
        {% else %}
            {% if service.image is defined and service.image is not empty %}
                {% set image = service.image|first %}
                {% set image_mobile = service.image_mobile|first|default(image) %}
                {% set variant = service.variant|default('landscape') %}
                {% set mobile_variant = service.mobile_variant|default('landscape') %}
            {% endif %}
        {% endif %}

        {% set has_image = image is not empty %}

        <div class="relative rounded-[2rem] border border-slate-100 dark:border-slate-700 hover:shadow-2xl transition-all group min-w-0 overflow-hidden h-full flex flex-col text-left {{ not has_image ? 'bg-white dark:bg-slate-800 p-8' : 'bg-slate-900' }}">
            {% if has_image %}
                {# Full Background Image #}
                <div class="absolute inset-0 z-0">
                    <picture>
                        <source media="(max-width: 639px)" srcset="{{ image_mobile.thumbnails[mobile_variant ~ '-md']|default(image_mobile.url) }}">
                        <img src="{{ image.thumbnails[variant ~ '-lg']|default(image.url) }}"
                             alt="{{ image.title|default(service.title) }}"
                             class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                             style="object-position: {{ image.focusX|default(50) }}% {{ image.focusY|default(50) }}%">
                    </picture>
                    <div class="absolute inset-0 bg-gradient-to-t from-slate-900 via-slate-900/40 to-transparent"></div>
                </div>
            {% endif %}

            <div class="relative z-10 flex flex-col h-full {{ has_image ? 'p-8 pt-24' : '' }}">
                <div class="w-16 h-16 rounded-2xl flex items-center justify-center mb-6 transition-colors flex-shrink-0 {{ has_image ? 'bg-white/20 backdrop-blur-md group-hover:bg-primary' : 'bg-blue-50 dark:bg-blue-900/20 group-hover:bg-primary' }}">
                    {% if not is_page and service.icon is defined and service.icon is not empty %}
                        {% set icon = service.icon|first %}
                        <img src="{{ icon.url }}" alt="{{ icon.title }}" class="w-8 h-8 object-contain {{ has_image ? '' : 'dark:invert group-hover:invert-0' }}">
                    {% else %}
                        <span class="material-symbols-outlined {{ has_image ? 'text-white' : 'text-primary' }} group-hover:text-white text-3xl">medical_services</span>
                    {% endif %}
                </div>

                <h3 class="text-2xl font-bold mb-4 break-words {{ has_image ? 'text-white' : 'text-slate-900 dark:text-white' }}">{{ service.title }}</h3>

                <div class="mb-6 leading-relaxed break-words flex-grow {{ has_image ? 'text-white/90' : 'text-slate-600 dark:text-slate-400' }}">
                    {% if is_page %}
                        {{ service.excerpt.description|default(service.title) }}
                    {% else %}
                        {{ service.description|raw }}
                    {% endif %}
                </div>

                {% if not is_page and service.features is defined and service.features is not empty %}
                    <ul class="space-y-3 mb-8 text-left">
                        {% for feature in service.features %}
                            <li class="flex items-center gap-2 text-sm min-w-0 {{ has_image ? 'text-white/80' : 'text-slate-500 dark:text-slate-400' }}">
                                <span class="material-symbols-outlined text-primary text-base flex-shrink-0">check_circle</span>
                                <span class="truncate">{{ feature.text }}</span>
                            </li>
                        {% endfor %}
                    </ul>
                {% endif %}

                {% set link = is_page ? sulu_content_path(service.url) : (service.link is defined and service.link is not empty ? sulu_content_path(service.link|first.url) : null) %}
                {% if link %}
                    <a class="inline-flex items-center font-bold hover:gap-2 transition-all mt-auto {{ has_image ? 'text-white' : 'text-primary' }}" href="{{ link }}">
                        {{ 'Mehr erfahren'|trans }} <span class="material-symbols-outlined ml-1">arrow_forward</span>
                    </a>
                {% endif %}
            </div>
        </div>
    {% endmacro %}

    {# News / Aktuelles Section #}
    {% if content.aktuelles_blocks is not empty %}
        <section class="py-24 bg-white dark:bg-slate-900 transition-colors overflow-hidden" id="aktuelles">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="text-center mb-12 sm:mb-16">
                    <h2 class="text-3xl sm:text-4xl font-display font-bold text-slate-900 dark:text-white mb-4 break-words">{{ content.aktuelles_title|default('Aktuelles'|trans) }}</h2>
                </div>
                <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
                    {% for item in content.aktuelles_blocks %}
                        {% set bgColor = 'bg-blue-50 dark:bg-blue-900/20 border-blue-100 dark:border-blue-800' %}
                        {% set iconColor = 'text-primary' %}
                        {% if item.news_type == 'warning' %}
                            {% set bgColor = 'bg-amber-50 dark:bg-amber-900/20 border-amber-100 dark:border-amber-800' %}
                            {% set iconColor = 'text-amber-600 dark:text-amber-400' %}
                        {% elseif item.news_type == 'success' %}
                            {% set bgColor = 'bg-green-50 dark:bg-green-900/20 border-green-100 dark:border-green-800' %}
                            {% set iconColor = 'text-green-600 dark:text-green-400' %}
                        {% endif %}

                        <div class="{{ bgColor }} p-8 rounded-[2rem] border transition-all hover:shadow-lg min-w-0 overflow-hidden">
                            <div class="flex items-center gap-4 mb-6">
                                <div class="w-12 h-12 rounded-xl bg-white dark:bg-slate-800 flex items-center justify-center {{ iconColor }} shadow-sm p-2 flex-shrink-0">
                                    {% if item.icon is not empty %}
                                        {% set icon = item.icon|first %}
                                        <img src="{{ icon.url }}" alt="{{ icon.title }}" class="w-full h-full object-contain">
                                    {% else %}
                                        <span class="material-symbols-outlined text-2xl">notifications</span>
                                    {% endif %}
                                </div>
                                <div class="min-w-0">
                                    <h3 class="text-xl font-bold text-slate-900 dark:text-white truncate">{{ item.title }}</h3>
                                    {% if item.date is not empty %}
                                        <p class="text-sm text-slate-500 dark:text-slate-400 truncate">{{ item.date }}</p>
                                    {% endif %}
                                </div>
                            </div>
                            <div class="prose prose-slate dark:prose-invert max-w-none text-slate-600 dark:text-slate-400 break-words overflow-hidden">
                                {{ item.text|raw }}
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </section>
    {% endif %}

    {# Contact Section #}
    <section class="py-24 bg-white dark:bg-slate-900 overflow-hidden" id="contact">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid lg:grid-cols-2 gap-16 items-center">
                <div class="min-w-0 overflow-hidden">
                    <h2 class="text-3xl sm:text-4xl font-display font-bold text-slate-900 dark:text-white mb-8 break-words">{{ content.visit_title|default('Besuchen Sie uns'|trans) }}</h2>
                    <div class="space-y-6">
                        {% if addressSettings %}
                            {% if addressSettings.content.address is defined and addressSettings.content.address %}
                                <div class="flex items-start gap-4">
                                    <div class="bg-blue-50 dark:bg-slate-800 p-3 rounded-lg flex-shrink-0">
                                        <span class="material-symbols-outlined text-primary">location_on</span>
                                    </div>
                                    <div class="min-w-0">
                                        <h4 class="font-bold text-slate-900 dark:text-white text-lg truncate">{{ 'Unser Standort'|trans }}</h4>
                                        <div class="text-slate-600 dark:text-slate-400 break-words overflow-hidden">
                                            {{ addressSettings.content.address|raw }}
                                        </div>
                                    </div>
                                </div>
                            {% endif %}
                            <div class="flex items-start gap-4">
                                <div class="bg-blue-50 dark:bg-slate-800 p-3 rounded-lg flex-shrink-0">
                                    <span class="material-symbols-outlined text-primary">schedule</span>
                                </div>
                                <div class="min-w-0">
                                    <h4 class="font-bold text-slate-900 dark:text-white text-lg truncate">{{ 'Öffnungszeiten'|trans }}</h4>
                                    <div class="text-slate-600 dark:text-slate-400 break-words overflow-hidden">
                                        {% if addressSettings.content.hours is defined and addressSettings.content.hours is not empty %}
                                            {% for entry in addressSettings.content.hours %}
                                                {{ entry.days }}: {{ entry.time }}{% if not loop.last %}<br/>{% endif %}
                                            {% endfor %}
                                        {% else %}
                                            {{ 'Mo - Fr: 08:00 - 18:00'|trans }}<br/>
                                            {{ 'Sa: 09:00 - 14:00'|trans }}
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                            {% if (addressSettings.content.email is defined and addressSettings.content.email) or (addressSettings.content.phone is defined and addressSettings.content.phone) %}
                                <div class="flex items-start gap-4">
                                    <div class="bg-blue-50 dark:bg-slate-800 p-3 rounded-lg flex-shrink-0">
                                        <span class="material-symbols-outlined text-primary">alternate_email</span>
                                    </div>
                                    <div class="min-w-0">
                                        <h4 class="font-bold text-slate-900 dark:text-white text-lg truncate">{{ 'E-Mail & Telefon'|trans }}</h4>
                                        <div class="text-slate-600 dark:text-slate-400 break-words overflow-hidden">
                                            {% if addressSettings.content.email %}
                                                <a href="mailto:{{ addressSettings.content.email }}" class="hover:text-primary transition-colors block truncate">{{ addressSettings.content.email }}</a>
                                            {% endif %}
                                            {% if addressSettings.content.phone %}
                                                <a href="tel:{{ addressSettings.content.phone|replace({' ': ''}) }}" class="hover:text-primary transition-colors block truncate">{{ addressSettings.content.phone }}</a>
                                            {% endif %}
                                        </div>
                                    </div>
                                </div>
                            {% endif %}
                        {% endif %}
                    </div>
                    {% if content.emergency_text is not empty %}
                        <div class="mt-10 p-6 bg-primary rounded-2xl text-white overflow-hidden">
                            <h4 class="text-xl font-bold mb-2 break-words">{{ content.emergency_title|default('Notfalltermin?'|trans) }}</h4>
                            <div class="opacity-90 mb-6 break-words overflow-hidden">
                                {{ content.emergency_text|raw }}
                            </div>
                            {% if addressSettings and addressSettings.content.phone %}
                                <a class="bg-white text-primary px-6 py-3 rounded-xl font-bold inline-flex items-center gap-2 hover:bg-slate-100 transition-colors max-w-full" href="tel:{{ addressSettings.content.phone|replace({' ': ''}) }}">
                                    <span class="material-symbols-outlined flex-shrink-0">phone_in_talk</span>
                                    <span class="truncate">{{ 'Jetzt anrufen'|trans }}</span>
                                </a>
                            {% endif %}
                        </div>
                    {% endif %}
                </div>
                <div class="rounded-[2.5rem] overflow-hidden shadow-2xl h-[500px] border-4 border-white dark:border-slate-800 relative group max-w-full">
                    {% set maps_url = content.map_link|default(addressSettings.content.map_link|default('')) %}
                    {% if maps_url is not empty %}
                        <iframe
                            src="{{ maps_url }}"
                            width="100%"
                            height="100%"
                            style="border:0;"
                            allowfullscreen=""
                            loading="lazy"
                            class="opacity-80 dark:opacity-40">
                        </iframe>
                        <div class="absolute inset-0 pointer-events-none flex items-center justify-center">
                            <div class="bg-primary p-3 rounded-full shadow-2xl animate-bounce">
                                <span class="material-symbols-outlined text-white text-3xl">location_on</span>
                            </div>
                        </div>
                    {% else %}
                        <img alt="Map Location" class="w-full h-full object-cover" src="https://images.unsplash.com/photo-1526778548025-fa2f459cd5c1?q=80&w=2033&auto=format&fit=crop">
                        <div class="absolute inset-0 bg-primary/10 group-hover:bg-transparent transition-colors"></div>
                        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2">
                            <div class="relative">
                                <div class="absolute inset-0 bg-primary animate-ping rounded-full opacity-75"></div>
                                <div class="relative bg-primary w-12 h-12 rounded-full flex items-center justify-center border-4 border-white shadow-xl">
                                    <span class="material-symbols-outlined text-white">location_on</span>
                                </div>
                            </div>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </section>
{% endblock %}
