{% extends 'base.html.twig' %}

{% block content %}
    <section class="hero">
        <div class="container">
            <h1>{{ content.title }}</h1>
            {% if content.subtitle is not empty %}
                <p>{{ content.subtitle }}</p>
            {% endif %}
            <a href="#contact" class="btn">Book Appointment</a>
        </div>
    </section>

    {% if content.article is not empty %}
        <section class="section">
            <div class="container">
                {{ content.article|raw }}
            </div>
        </section>
    {% endif %}

    {% if content.services_list is not empty %}
        <section class="section" style="background-color: #f9f9f9;">
            <div class="container">
                {% if content.services_title is not empty %}
                    <h2 style="text-align: center; margin-bottom: 3rem;">{{ content.services_title }}</h2>
                {% endif %}

                <div class="grid">
                    {% for service in content.services_list %}
                        <div class="card">
                            {% if service.icon is not empty %}
                                <div style="font-size: 2rem; color: var(--primary-color); margin-bottom: 1rem;">
                                    <i class="ti ti-{{ service.icon }}"></i>
                                </div>
                            {% endif %}
                            <h3>{{ service.title }}</h3>
                            <p>{{ service.description }}</p>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </section>
    {% endif %}

    {% set a = sulu_snippet_load_by_area('address') %}
    {{ dump(a) }}
    {% if content.address is not empty %}

    {% endif %}
{% endblock %}
