{% extends 'base.html.twig' %}

{% block content %}
    <article class="pt-32 pb-24 bg-white dark:bg-slate-900 transition-colors duration-300 w-full max-w-full overflow-x-hidden">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
            <div class="grid lg:grid-cols-12 gap-12 items-start w-full min-w-0">
                {# Sidebar / Image #}
                <div class="lg:col-span-5 space-y-8 animate-in fade-in slide-in-from-left-8 duration-700 w-full max-w-[500px] mx-auto lg:max-w-none min-w-0 overflow-hidden flex flex-col">
                    {% set memberLayout = content.image_layout|default('vertical') %}
                    <div class="relative rounded-[2.5rem] overflow-hidden shadow-2xl {{ memberLayout == 'square' ? 'aspect-square' : 'aspect-[4/5]' }} bg-slate-100 dark:bg-slate-800 w-full max-w-full">
                        {% if content.image is defined and content.image is not empty %}
                            {% set image = content.image|first %}
                            {% set format = memberLayout == 'square' ? 'square-high' : 'vertical-high' %}
                            <img src="{{ image.thumbnails[format]|default(image.thumbnails['sulu-400x400-inset'])|default(image.url) }}"
                                 alt="{{ content.title }}"
                                 class="w-full h-full object-cover max-w-full block"
                                 style="object-position: {{ image.focusX|default(50) }}% {{ image.focusY|default(50) }}%">
                        {% else %}
                            <img alt="{{ content.title }}" class="w-full h-full object-cover max-w-full block" src="https://i.pravatar.cc/800?u={{ content.title|url_encode }}">
                        {% endif %}
                    </div>

                    {% if content.contact_info is not empty %}
                        {% set contact = content.contact_info|first %}
                        <div class="bg-slate-50 dark:bg-slate-800/50 rounded-3xl p-8 border border-slate-100 dark:border-slate-700">
                            <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-6">{{ 'Kontakt'|trans }}</h3>
                            <div class="space-y-4">
                                {% if contact.email is not empty %}
                                    <a href="mailto:{{ contact.email }}" class="flex items-center gap-4 text-slate-600 dark:text-slate-400 hover:text-primary transition-colors group">
                                        <div class="w-10 h-10 rounded-full bg-white dark:bg-slate-700 flex items-center justify-center shadow-sm group-hover:bg-primary group-hover:text-white transition-all">
                                            <span class="material-symbols-outlined text-sm">mail</span>
                                        </div>
                                        <span class="font-medium truncate">{{ contact.email }}</span>
                                    </a>
                                {% endif %}
                                {% if contact.phone is not empty %}
                                    <a href="tel:{{ contact.phone|replace({' ': ''}) }}" class="flex items-center gap-4 text-slate-600 dark:text-slate-400 hover:text-primary transition-colors group">
                                        <div class="w-10 h-10 rounded-full bg-white dark:bg-slate-700 flex items-center justify-center shadow-sm group-hover:bg-primary group-hover:text-white transition-all">
                                            <span class="material-symbols-outlined text-sm">call</span>
                                        </div>
                                        <span class="font-medium">{{ contact.phone }}</span>
                                    </a>
                                {% endif %}
                                {% if contact.calendar_url is not empty %}
                                    <a href="{{ contact.calendar_url }}" target="_blank" class="flex items-center gap-4 text-slate-600 dark:text-slate-400 hover:text-primary transition-colors group">
                                        <div class="w-10 h-10 rounded-full bg-white dark:bg-slate-700 flex items-center justify-center shadow-sm group-hover:bg-primary group-hover:text-white transition-all">
                                            <span class="material-symbols-outlined text-sm">calendar_month</span>
                                        </div>
                                        <span class="font-medium">{{ 'Termin buchen'|trans }}</span>
                                    </a>
                                {% endif %}
                            </div>
                        </div>
                    {% endif %}
                </div>

                {# Main Content #}
                <div class="lg:col-span-7 space-y-10 animate-in fade-in slide-in-from-right-8 duration-700 min-w-0 w-full overflow-hidden">
                    <div>
                        {% set role_label = content.role %}
                        {% if content.role == 'dentists' %}{% set role_label = 'Zahnärzte'|trans %}
                        {% elseif content.role == 'reception' %}{% set role_label = 'Empfang'|trans %}
                        {% elseif content.role == 'assistants' %}{% set role_label = 'Assistenz'|trans %}
                        {% elseif content.role == 'all' %}{% set role_label = 'Alle'|trans %}
                        {% endif %}
                        <span class="inline-block px-4 py-1 bg-blue-50 dark:bg-blue-900/30 text-primary text-sm font-bold rounded-lg uppercase tracking-wider mb-4">{{ role_label }}</span>
                        <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold text-slate-900 dark:text-white mb-6 break-words hyphens-auto min-w-0 w-full max-w-full overflow-hidden">{{ content.title }}</h1>
                        {% if content.description is not empty %}
                            <div class="text-xl text-slate-600 dark:text-slate-400 leading-relaxed font-medium break-words overflow-hidden">
                                {{ content.description|raw }}
                            </div>
                        {% endif %}
                    </div>

                    {% if content.article is not empty %}
                        <div class="prose prose-lg prose-slate dark:prose-invert max-w-none border-t border-slate-100 dark:border-slate-800 pt-10">
                            {{ content.article|raw }}
                        </div>
                    {% endif %}

                    {% if content.specialties is not empty %}
                        <div class="space-y-6 pt-10 border-t border-slate-100 dark:border-slate-800">
                            <h3 class="text-2xl font-bold text-slate-900 dark:text-white">{{ 'Tätigkeitsschwerpunkte'|trans }}</h3>
                            <div class="grid sm:grid-cols-2 gap-4">
                                {% for specialty in content.specialties %}
                                    <div class="flex items-center gap-3 p-4 bg-slate-50 dark:bg-slate-800/50 rounded-2xl border border-slate-100 dark:border-slate-700">
                                        <div class="w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center text-primary">
                                            <span class="material-symbols-outlined text-sm font-bold">check</span>
                                        </div>
                                        <span class="font-bold text-slate-700 dark:text-slate-300">{{ specialty.title }}</span>
                                    </div>
                                {% endfor %}
                            </div>
                        </div>
                    {% endif %}

                    <div class="pt-12">
                        <a href="{{ sulu_content_path('/team') }}" class="inline-flex items-center gap-2 text-primary font-bold hover:gap-4 transition-all">
                            <span class="material-symbols-outlined">arrow_back</span>
                            {{ 'Zurück zum Team'|trans }}
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </article>
{% endblock %}
