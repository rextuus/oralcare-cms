{% extends 'base.html.twig' %}

{% block content %}

    {% set common_settings = sulu_snippet_load_by_area('common_settings') %}
    {% set global_best_quality = common_settings.content.force_best_quality|default(false) %}
    <div class="pt-32 pb-20 px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto w-full max-w-full overflow-x-hidden">
        <div class="text-center mb-16 min-w-0 w-full overflow-hidden">
            <h1 class="text-4xl md:text-5xl font-bold mb-6 text-slate-900 dark:text-white break-words hyphens-auto min-w-0 w-full max-w-full overflow-hidden">{{ content.title }}</h1>
            <div id="role-description-container">
                <div id="default-subtitle" class="role-desc">
                    {% if content.subtitle is not empty %}
                        <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl mx-auto leading-relaxed break-words">
                            {{ content.subtitle|raw }}
                        </p>
                    {% endif %}
                </div>
                <div id="desc-dentists" class="role-desc hidden">
                    {% if content.text_dentists is not empty %}
                        <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl mx-auto leading-relaxed break-words">
                            {{ content.text_dentists|raw }}
                        </p>
                    {% endif %}
                </div>
                <div id="desc-reception" class="role-desc hidden">
                    {% if content.text_reception is not empty %}
                        <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl mx-auto leading-relaxed break-words">
                            {{ content.text_reception|raw }}
                        </p>
                    {% endif %}
                </div>
                <div id="desc-assistants" class="role-desc hidden">
                    {% if content.text_assistants is not empty %}
                        <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl mx-auto leading-relaxed break-words">
                            {{ content.text_assistants|raw }}
                        </p>
                    {% endif %}
                </div>
                <div id="desc-prophylaxis" class="role-desc hidden">
                    {% if content.text_prophylaxis is not empty %}
                        <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl mx-auto leading-relaxed break-words">
                            {{ content.text_prophylaxis|raw }}
                        </p>
                    {% endif %}
                </div>
            </div>
        </div>

        <div class="flex flex-wrap justify-center gap-3 mb-12" id="team-filter">
            <button data-filter="all" class="filter-btn px-6 py-2 rounded-full bg-primary text-white font-medium shadow-lg shadow-blue-500/20 hover:opacity-90 transition-all active-filter">{{ 'Alle'|trans }}</button>
            <button data-filter="dentists" class="filter-btn px-6 py-2 rounded-full bg-white dark:bg-slate-800 text-slate-600 dark:text-slate-300 font-medium border border-slate-200 dark:border-slate-700 hover:border-primary dark:hover:border-primary hover:text-primary dark:hover:border-primary transition-all">{{ 'Zahnärzte'|trans }}</button>
            <button data-filter="reception" class="filter-btn px-6 py-2 rounded-full bg-white dark:bg-slate-800 text-slate-600 dark:text-slate-300 font-medium border border-slate-200 dark:border-slate-700 hover:border-primary dark:hover:border-primary hover:text-primary dark:hover:border-primary transition-all">{{ 'Empfang'|trans }}</button>
            <button data-filter="assistants" class="filter-btn px-6 py-2 rounded-full bg-white dark:bg-slate-800 text-slate-600 dark:text-slate-300 font-medium border border-slate-200 dark:border-slate-700 hover:border-primary dark:hover:border-primary hover:text-primary dark:hover:border-primary transition-all">{{ 'Assistenz'|trans }}</button>
            <button data-filter="prophylaxis" class="filter-btn px-6 py-2 rounded-full bg-white dark:bg-slate-800 text-slate-600 dark:text-slate-300 font-medium border border-slate-200 dark:border-slate-700 hover:border-primary dark:hover:border-primary hover:text-primary dark:hover:border-primary transition-all">{{ 'Prophylaxe'|trans }}</button>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8" id="team-grid">
            {% for member in content.team_members %}
                {% set variant = member.variant|default('vertical') %}
                {% set mobile_variant = member.mobile_variant|default('vertical') %}
                {% set memberLink = member.link is not empty ? sulu_content_path(member.link|first.url) : null %}
                <div class="team-card group bg-white dark:bg-slate-800 rounded-3xl overflow-hidden border border-slate-100 dark:border-slate-700 transition-all duration-300 hover:shadow-2xl hover:shadow-slate-200 dark:hover:shadow-none hover:-translate-y-2"
                     data-category="{{ member.category|default('all') }}">
                    <div class="{{ variant == 'square' ? 'aspect-square' : (variant == 'horizontal' ? 'aspect-video' : 'aspect-[4/5]') }} overflow-hidden bg-slate-100 dark:bg-slate-900 relative">
                        {% if member.image is defined and (member.image is not empty or member.image_mobile is not empty) %}
                            {% set image = member.image|first %}
                            {% set image_mobile = member.image_mobile|first|default(image) %}

                            {% set quality = member.quality|default(global_best_quality ? 'best' : 'standard') %}
                            {% set mobile_quality = member.mobile_quality|default(global_best_quality ? 'best' : 'standard') %}
                            {% if quality == 'best' %}
                                {% set desktop_format = variant ~ '-xl' %}
                            {% else %}
                                {% set desktop_format = variant ~ '-lg' %}
                            {% endif %}
                            {% if mobile_quality == 'best' %}
                                {% set mobile_format = mobile_variant ~ '-xl' %}
                            {% else %}
                                {% set mobile_format = mobile_variant ~ '-md' %}
                            {% endif %}

                            <picture>
                                <source media="(max-width: 639px)" srcset="{{ image_mobile.thumbnails[mobile_format]|default(image_mobile.url) }}">
                                <img src="{{ image.thumbnails[desktop_format]|default(image.thumbnails['vertical-md'])|default(image.url) }}"
                                     alt="{{ member.name }}"
                                     class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-500"
                                     style="object-position: {{ image.focusX|default(50) }}% {{ image.focusY|default(50) }}%">
                            </picture>
                        {% else %}
                            <img alt="{{ member.name }}" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-500" src="https://i.pravatar.cc/400?u={{ member.name|url_encode }}">
                        {% endif %}

                        {% if memberLink %}
                            <a href="{{ memberLink }}" class="absolute inset-0 z-10" aria-label="{{ 'Detailseite von'|trans }} {{ member.name }}"></a>
                        {% endif %}
                    </div>
                    <div class="p-6">
                        {% set badgeColorClass = 'bg-blue-50 dark:bg-blue-900/30 text-primary' %}
                        {% if member.badge_color == 'purple' %}
                            {% set badgeColorClass = 'bg-purple-50 dark:bg-purple-900/30 text-purple-600 dark:text-purple-400' %}
                        {% elseif member.badge_color == 'teal' %}
                            {% set badgeColorClass = 'bg-teal-50 dark:bg-teal-900/30 text-teal-600 dark:text-teal-400' %}
                        {% elseif member.badge_color == 'amber' %}
                            {% set badgeColorClass = 'bg-amber-50 dark:bg-amber-900/30 text-amber-600 dark:text-amber-400' %}
                        {% endif %}

                        <span class="inline-block px-3 py-1 {{ badgeColorClass }} text-xs font-bold rounded-md uppercase tracking-wider mb-3">{{ member.role }}</span>
                        <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-1">
                            {% if memberLink %}
                                <a href="{{ memberLink }}" class="hover:text-primary transition-colors">{{ member.name }}</a>
                            {% else %}
                                {{ member.name }}
                            {% endif %}
                        </h3>
                        <p class="text-slate-500 dark:text-slate-400 text-sm mb-4 leading-relaxed">{{ member.description|raw }}</p>
                        <div class="flex gap-2 relative z-20">
                            {% if member.email is not empty %}
                                <a href="mailto:{{ member.email }}" class="p-2 rounded-full bg-slate-50 dark:bg-slate-700 hover:text-primary transition-colors">
                                    <span class="material-symbols-outlined text-sm">mail</span>
                                </a>
                            {% endif %}
                            {% if member.calendar_url is not empty %}
                                <a href="{{ member.calendar_url }}" target="_blank" class="p-2 rounded-full bg-slate-50 dark:bg-slate-700 hover:text-primary transition-colors">
                                    <span class="material-symbols-outlined text-sm">calendar_month</span>
                                </a>
                            {% endif %}
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>

        {% if content.careers_title is not empty or content.careers_text is not empty %}
            <div class="mt-20 bg-primary/10 dark:bg-slate-800/50 rounded-[40px] p-8 md:p-12 text-center border border-primary/20">
                <h2 class="text-2xl md:text-3xl font-bold mb-4 text-slate-900 dark:text-white">{{ content.careers_title }}</h2>
                <p class="text-slate-600 dark:text-slate-400 mb-8 max-w-xl mx-auto">{{ content.careers_text|raw }}</p>
                {% if content.careers_button_link is not empty %}
                    <a href="{{ sulu_content_path(content.careers_button_link|first.url) }}" class="bg-primary text-white font-bold px-8 py-3.5 rounded-full hover:bg-blue-600 transition-colors">
                        {{ content.careers_button_text|default('Offene Stellen ansehen'|trans) }}
                    </a>
                {% endif %}
            </div>
        {% endif %}
    </div>
{% endblock %}

{% block javascripts %}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const filterButtons = document.querySelectorAll('.filter-btn');
            const teamCards = document.querySelectorAll('.team-card');

            filterButtons.forEach(button => {
                button.addEventListener('click', () => {
                    const filter = button.getAttribute('data-filter');

                    // Update active button state
                    filterButtons.forEach(btn => {
                        btn.classList.remove('bg-primary', 'text-white', 'shadow-lg', 'shadow-blue-500/20');
                        btn.classList.add('bg-white', 'dark:bg-slate-800', 'text-slate-600', 'dark:text-slate-300', 'border', 'border-slate-200', 'dark:border-slate-700');
                    });

                    button.classList.remove('bg-white', 'dark:bg-slate-800', 'text-slate-600', 'dark:text-slate-300', 'border', 'border-slate-200', 'dark:border-slate-700');
                    button.classList.add('bg-primary', 'text-white', 'shadow-lg', 'shadow-blue-500/20');

                    // Filter cards
                    teamCards.forEach(card => {
                        if (filter === 'all' || card.getAttribute('data-category') === filter) {
                            card.style.display = 'block';
                            setTimeout(() => {
                                card.style.opacity = '1';
                                card.style.transform = 'translateY(0)';
                            }, 10);
                        } else {
                            card.style.opacity = '0';
                            card.style.transform = 'translateY(20px)';
                            setTimeout(() => {
                                card.style.display = 'none';
                            }, 300);
                        }
                    });

                    // Update role description
                    const roleDescriptions = document.querySelectorAll('.role-desc');
                    roleDescriptions.forEach(desc => desc.classList.add('hidden'));

                    const activeDesc = document.getElementById(filter === 'all' ? 'default-subtitle' : 'desc-' + filter);
                    if (activeDesc) {
                        activeDesc.classList.remove('hidden');
                    }
                });
            });
        });
    </script>
{% endblock %}
