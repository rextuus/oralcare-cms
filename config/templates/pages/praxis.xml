<?xml version="1.0" ?>
<template xmlns="http://schemas.sulu.io/template/template"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://schemas.sulu.io/template/template http://schemas.sulu.io/template/template-1.0.xsd">

    <key>praxis</key>

    <view>pages/praxis</view>
    <controller>Sulu\Content\UserInterface\Controller\Website\ContentController::indexAction</controller>
    <cacheLifetime>86400</cacheLifetime>

    <meta>
        <title lang="en">Praxis / Room Tour</title>
        <title lang="de">Praxis / Rundgang</title>
    </meta>

    <properties>
        <property name="title" type="text_line" mandatory="true">
            <meta>
                <title lang="en">Title</title>
                <title lang="de">Titel</title>
            </meta>
            <params>
                <param name="headline" value="true"/>
            </params>

            <tag name="sulu.rlp.part"/>
        </property>

        <property name="url" type="route" mandatory="true">
            <meta>
                <title lang="en">Resourcelocator</title>
                <title lang="de">Adresse</title>
            </meta>

            <tag name="sulu.rlp"/>
            <tag name="sulu.node.navigation"/>
        </property>

        <section name="hero_section">
            <meta>
                <title lang="en">Hero Section</title>
                <title lang="de">Hero Bereich</title>
            </meta>
            <properties>
                <property name="hero_image" type="media_selection">
                    <meta>
                        <title lang="en">Hero Image (Desktop)</title>
                        <title lang="de">Hero Bild (Desktop)</title>
                    </meta>
                    <params>
                        <param name="types" value="image"/>
                        <param name="max" value="1"/>
                    </params>
                </property>
                <property name="hero_image_mobile" type="media_selection">
                    <meta>
                        <title lang="en">Hero Image (Mobile)</title>
                        <title lang="de">Hero Bild (Mobil)</title>
                    </meta>
                    <params>
                        <param name="types" value="image"/>
                        <param name="max" value="1"/>
                    </params>
                </property>
                <property name="hero_subtitle" type="text_editor">
                    <meta>
                        <title lang="en">Hero Subtitle</title>
                        <title lang="de">Hero Untertitel</title>
                    </meta>
                </property>
            </properties>
        </section>

        <section name="introduction">
            <meta>
                <title lang="en">Introduction</title>
                <title lang="de">Einleitung</title>
            </meta>
            <properties>
                <property name="intro_text" type="text_editor">
                    <meta>
                        <title lang="en">Intro Text</title>
                        <title lang="de">Einleitungstext</title>
                    </meta>
                </property>
            </properties>
        </section>

        <section name="room_tour">
            <meta>
                <title lang="en">Room Tour / Gallery</title>
                <title lang="de">Praxisrundgang / Galerie</title>
            </meta>
            <properties>
                <property name="gallery_images" type="block">
                    <meta>
                        <title lang="en">Gallery Items</title>
                        <title lang="de">Galerie Elemente</title>
                    </meta>
                    <types>
                        <type name="image_item">
                            <meta>
                                <title lang="en">Image with Caption</title>
                                <title lang="de">Bild mit Beschriftung</title>
                            </meta>
                            <properties>
                                <property name="image" type="media_selection">
                                    <meta>
                                        <title lang="en">Image (Desktop)</title>
                                        <title lang="de">Bild (Desktop)</title>
                                    </meta>
                                    <params>
                                        <param name="types" value="image"/>
                                        <param name="max" value="1"/>
                                    </params>
                                </property>
                                <property name="image_mobile" type="media_selection">
                                    <meta>
                                        <title lang="en">Image (Mobile)</title>
                                        <title lang="de">Bild (Mobil)</title>
                                    </meta>
                                    <params>
                                        <param name="types" value="image"/>
                                        <param name="max" value="1"/>
                                    </params>
                                </property>
                                <property name="caption" type="text_line">
                                    <meta>
                                        <title lang="en">Caption</title>
                                        <title lang="de">Bildunterschrift</title>
                                    </meta>
                                </property>
                                <property name="layout" type="single_select">
                                    <meta>
                                        <title lang="en">Layout Size</title>
                                        <title lang="de">Layout Größe</title>
                                    </meta>
                                    <params>
                                        <param name="values" type="collection">
                                            <param name="normal">
                                                <meta>
                                                    <title lang="en">Normal</title>
                                                    <title lang="de">Normal</title>
                                                </meta>
                                            </param>
                                            <param name="wide">
                                                <meta>
                                                    <title lang="en">Wide (2 columns)</title>
                                                    <title lang="de">Breit (2 Spalten)</title>
                                                </meta>
                                            </param>
                                        </param>
                                        <param name="default" value="normal"/>
                                    </params>
                                </property>
                            </properties>
                        </type>
                    </types>
                </property>
            </properties>
        </section>

        <section name="cta_section">
            <meta>
                <title lang="en">Call to Action</title>
                <title lang="de">Call to Action</title>
            </meta>
            <properties>
                <property name="cta_title" type="text_line">
                    <meta>
                        <title lang="en">CTA Title</title>
                        <title lang="de">CTA Titel</title>
                    </meta>
                </property>
                <property name="cta_subtitle" type="text_editor">
                    <meta>
                        <title lang="en">CTA Subtitle</title>
                        <title lang="de">CTA Untertitel</title>
                    </meta>
                </property>
                <property name="cta_button_text" type="text_line">
                    <meta>
                        <title lang="en">Button Text</title>
                        <title lang="de">Button Text</title>
                    </meta>
                </property>
                <property name="cta_button_link" type="page_selection">
                    <meta>
                        <title lang="en">Button Link</title>
                        <title lang="de">Button Link</title>
                    </meta>
                    <params>
                        <param name="max" value="1"/>
                    </params>
                </property>
            </properties>
        </section>
    </properties>
</template>
