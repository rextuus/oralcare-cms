<?xml version="1.0" ?>
<template xmlns="http://schemas.sulu.io/template/template"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://schemas.sulu.io/template/template http://schemas.sulu.io/template/template-1.0.xsd">

    <key>homepage</key>

    <view>pages/homepage</view>
    <controller>Sulu\Content\UserInterface\Controller\Website\ContentController::indexAction</controller>
    <cacheLifetime>86400</cacheLifetime>

    <meta>
        <title lang="en">Homepage</title>
        <title lang="de">Startseite</title>
    </meta>

    <properties>
        <property name="title" type="text_line" mandatory="true">
            <meta>
                <title lang="en">Title</title>
                <title lang="de">Titel</title>
            </meta>
            <params>
                <param name="headline" value="true"/>
            </params>

            <tag name="sulu.rlp.part"/>
        </property>

        <property name="url" type="route" mandatory="true">
            <meta>
                <title lang="en">Resourcelocator</title>
                <title lang="de">Adresse</title>
            </meta>

            <tag name="sulu.rlp"/>
        </property>

        <section name="hero">
            <meta>
                <title lang="en">Hero</title>
                <title lang="de">Hero</title>
            </meta>
            <properties>
                <property name="hero_badge" type="text_line">
                    <meta>
                        <title lang="en">Badge</title>
                        <title lang="de">Badge</title>
                    </meta>
                </property>
                <property name="hero_subtitle" type="text_editor">
                    <meta>
                        <title lang="en">Subtitle</title>
                        <title lang="de">Untertitel</title>
                    </meta>
                </property>
                <property name="hero_image" type="media_selection">
                    <meta>
                        <title lang="en">Hero Image (Desktop)</title>
                        <title lang="de">Hero Bild (Desktop)</title>
                    </meta>
                    <params>
                        <param name="types" value="image"/>
                        <param name="max" value="1"/>
                    </params>
                </property>
                <property name="hero_image_mobile" type="media_selection">
                    <meta>
                        <title lang="en">Hero Image (Mobile)</title>
                        <title lang="de">Hero Bild (Mobil)</title>
                    </meta>
                    <params>
                        <param name="types" value="image"/>
                        <param name="max" value="1"/>
                    </params>
                </property>
                <property name="hero_image_variant" type="single_select">
                    <meta>
                        <title lang="en">Hero Image Variant (Desktop)</title>
                        <title lang="de">Hero Bild-Variante (Desktop)</title>
                    </meta>
                    <params>
                        <param name="values" type="collection">
                            <param name="vertical">
                                <meta><title lang="en">Vertical</title><title lang="de">Vertikal</title></meta>
                            </param>
                            <param name="horizontal">
                                <meta><title lang="en">Horizontal</title><title lang="de">Horizontal</title></meta>
                            </param>
                            <param name="square">
                                <meta><title lang="en">Square</title><title lang="de">Quadratisch</title></meta>
                            </param>
                        </param>
                        <param name="default" value="vertical"/>
                    </params>
                </property>
                <property name="hero_image_quality" type="single_select">
                    <meta>
                        <title lang="en">Hero Image Quality (Desktop)</title>
                        <title lang="de">Hero Bild-Qualität (Desktop)</title>
                    </meta>
                    <params>
                        <param name="values" type="collection">
                            <param name="standard">
                                <meta><title lang="en">Standard</title><title lang="de">Standard</title></meta>
                            </param>
                            <param name="best">
                                <meta><title lang="en">Best (High Res)</title><title lang="de">Beste (Hohe Auflösung)</title></meta>
                            </param>
                        </param>
                        <param name="default" value="standard"/>
                    </params>
                </property>
                <property name="hero_image_mobile_variant" type="single_select">
                    <meta>
                        <title lang="en">Hero Image Variant (Mobile)</title>
                        <title lang="de">Hero Bild-Variante (Mobil)</title>
                    </meta>
                    <params>
                        <param name="values" type="collection">
                            <param name="vertical">
                                <meta><title lang="en">Vertical</title><title lang="de">Vertikal</title></meta>
                            </param>
                            <param name="horizontal">
                                <meta><title lang="en">Horizontal</title><title lang="de">Horizontal</title></meta>
                            </param>
                            <param name="square">
                                <meta><title lang="en">Square</title><title lang="de">Quadratisch</title></meta>
                            </param>
                        </param>
                        <param name="default" value="vertical"/>
                    </params>
                </property>
                <property name="hero_image_mobile_quality" type="single_select">
                    <meta>
                        <title lang="en">Hero Image Quality (Mobile)</title>
                        <title lang="de">Hero Bild-Qualität (Mobil)</title>
                    </meta>
                    <params>
                        <param name="values" type="collection">
                            <param name="standard">
                                <meta><title lang="en">Standard</title><title lang="de">Standard</title></meta>
                            </param>
                            <param name="best">
                                <meta><title lang="en">Best (High Res)</title><title lang="de">Beste (Hohe Auflösung)</title></meta>
                            </param>
                        </param>
                        <param name="default" value="standard"/>
                    </params>
                </property>
                <section name="hero_availability">
                    <meta>
                        <title lang="en">Availability Card</title>
                        <title lang="de">Verfügbarkeitskarte</title>
                    </meta>
                    <properties>
                        <property name="hero_avail_title" type="text_line">
                            <meta>
                                <title lang="en">Title</title>
                                <title lang="de">Titel</title>
                            </meta>
                        </property>
                        <property name="hero_avail_text" type="text_line">
                            <meta>
                                <title lang="en">Availability Text</title>
                                <title lang="de">Verfügbarkeitstext</title>
                            </meta>
                        </property>
                    </properties>
                </section>
            </properties>
        </section>

        <section name="about">
            <meta>
                <title lang="en">About</title>
                <title lang="de">Über uns</title>
            </meta>
            <properties>
                <property name="about_badge" type="text_line">
                    <meta>
                        <title lang="en">Badge</title>
                        <title lang="de">Badge</title>
                    </meta>
                </property>
                <property name="about_title" type="text_line">
                    <meta>
                        <title lang="en">Title</title>
                        <title lang="de">Titel</title>
                    </meta>
                </property>
                <property name="about_description_1" type="text_editor">
                    <meta>
                        <title lang="en">Description 1</title>
                        <title lang="de">Beschreibung 1</title>
                    </meta>
                </property>
                <property name="about_description_2" type="text_editor">
                    <meta>
                        <title lang="en">Description 2</title>
                        <title lang="de">Beschreibung 2</title>
                    </meta>
                </property>
                <property name="about_images" type="block">
                    <meta>
                        <title lang="en">About Images (4)</title>
                        <title lang="de">Bilder Über uns (4)</title>
                    </meta>
                    <params>
                        <param name="max" value="4"/>
                    </params>
                    <types>
                        <type name="about_image">
                            <meta>
                                <title lang="en">Image</title>
                                <title lang="de">Bild</title>
                            </meta>
                            <properties>
                                <property name="image" type="media_selection">
                                    <meta>
                                        <title lang="en">Image (Desktop)</title>
                                        <title lang="de">Bild (Desktop)</title>
                                    </meta>
                                    <params>
                                        <param name="types" value="image"/>
                                        <param name="max" value="1"/>
                                    </params>
                                </property>
                                <property name="image_mobile" type="media_selection">
                                    <meta>
                                        <title lang="en">Image (Mobile)</title>
                                        <title lang="de">Bild (Mobil)</title>
                                    </meta>
                                    <params>
                                        <param name="types" value="image"/>
                                        <param name="max" value="1"/>
                                    </params>
                                </property>
                                <property name="variant" type="single_select">
                                    <meta>
                                        <title lang="en">Variant (Desktop)</title>
                                        <title lang="de">Variante (Desktop)</title>
                                    </meta>
                                    <params>
                                        <param name="values" type="collection">
                                            <param name="square">
                                                <meta><title lang="en">Square</title><title lang="de">Quadratisch</title></meta>
                                            </param>
                                            <param name="vertical">
                                                <meta><title lang="en">Vertical</title><title lang="de">Vertikal</title></meta>
                                            </param>
                                            <param name="horizontal">
                                                <meta><title lang="en">Horizontal</title><title lang="de">Horizontal</title></meta>
                                            </param>
                                        </param>
                                        <param name="default" value="square"/>
                                    </params>
                                </property>
                                <property name="quality" type="single_select">
                                    <meta>
                                        <title lang="en">Quality</title>
                                        <title lang="de">Qualität</title>
                                    </meta>
                                    <params>
                                        <param name="values" type="collection">
                                            <param name="standard">
                                                <meta><title lang="en">Standard</title><title lang="de">Standard</title></meta>
                                            </param>
                                            <param name="best">
                                                <meta><title lang="en">Best (High Res)</title><title lang="de">Beste (Hohe Auflösung)</title></meta>
                                            </param>
                                        </param>
                                        <param name="default" value="standard"/>
                                    </params>
                                </property>
                                <property name="mobile_variant" type="single_select">
                                    <meta>
                                        <title lang="en">Variant (Mobile)</title>
                                        <title lang="de">Variante (Mobil)</title>
                                    </meta>
                                    <params>
                                        <param name="values" type="collection">
                                            <param name="square">
                                                <meta><title lang="en">Square</title><title lang="de">Quadratisch</title></meta>
                                            </param>
                                            <param name="vertical">
                                                <meta><title lang="en">Vertical</title><title lang="de">Vertikal</title></meta>
                                            </param>
                                            <param name="horizontal">
                                                <meta><title lang="en">Horizontal</title><title lang="de">Horizontal</title></meta>
                                            </param>
                                        </param>
                                        <param name="default" value="square"/>
                                    </params>
                                </property>
                                <property name="mobile_quality" type="single_select">
                                    <meta>
                                        <title lang="en">Quality (Mobile)</title>
                                        <title lang="de">Qualität (Mobil)</title>
                                    </meta>
                                    <params>
                                        <param name="values" type="collection">
                                            <param name="standard">
                                                <meta><title lang="en">Standard</title><title lang="de">Standard</title></meta>
                                            </param>
                                            <param name="best">
                                                <meta><title lang="en">Best (High Res)</title><title lang="de">Beste (Hohe Auflösung)</title></meta>
                                            </param>
                                        </param>
                                        <param name="default" value="standard"/>
                                    </params>
                                </property>
                            </properties>
                        </type>
                    </types>
                </property>
                <property name="about_features" type="block">
                    <meta>
                        <title lang="en">Features</title>
                        <title lang="de">Merkmale</title>
                    </meta>
                    <types>
                        <type name="feature">
                            <meta>
                                <title lang="en">Feature</title>
                                <title lang="de">Merkmal</title>
                            </meta>
                            <properties>
                                <property name="title" type="text_line">
                                    <meta>
                                        <title lang="en">Title</title>
                                        <title lang="de">Titel</title>
                                    </meta>
                                </property>
                                <property name="subtitle" type="text_line">
                                    <meta>
                                        <title lang="en">Subtitle</title>
                                        <title lang="de">Untertitel</title>
                                    </meta>
                                </property>
                                <property name="icon" type="media_selection">
                                    <meta>
                                        <title lang="en">Icon</title>
                                        <title lang="de">Icon</title>
                                    </meta>
                                    <params>
                                        <param name="types" value="image"/>
                                        <param name="max" value="1"/>
                                    </params>
                                </property>
                            </properties>
                        </type>
                    </types>
                </property>
            </properties>
        </section>

        <section name="services">
            <meta>
                <title lang="en">Services Section</title>
                <title lang="de">Leistungsbereich</title>
            </meta>
            <properties>
                <property name="services_title" type="text_line">
                    <meta>
                        <title lang="en">Services Title</title>
                        <title lang="de">Leistungen Titel</title>
                    </meta>
                </property>
                <property name="services_subtitle" type="text_editor">
                    <meta>
                        <title lang="en">Services Subtitle</title>
                        <title lang="de">Leistungen Untertitel</title>
                    </meta>
                </property>
                <property name="services_selection" type="page_selection">
                    <meta>
                        <title lang="en">Linked Services (Optional selection from pages)</title>
                        <title lang="de">Verlinkte Leistungen (Optionale Auswahl aus Seiten)</title>
                    </meta>
                </property>
                <property name="services_list" type="block">
                    <meta>
                        <title lang="en">Services</title>
                        <title lang="de">Leistungen</title>
                    </meta>
                    <types>
                        <type name="service">
                            <meta>
                                <title lang="en">Service</title>
                                <title lang="de">Leistung</title>
                            </meta>
                            <properties>
                                <property name="title" type="text_line">
                                    <meta>
                                        <title lang="en">Title</title>
                                        <title lang="de">Titel</title>
                                    </meta>
                                </property>
                                <property name="description" type="text_editor">
                                    <meta>
                                        <title lang="en">Description</title>
                                        <title lang="de">Beschreibung</title>
                                    </meta>
                                </property>
                                <property name="icon" type="media_selection">
                                    <meta>
                                        <title lang="en">Icon</title>
                                        <title lang="de">Icon</title>
                                    </meta>
                                    <params>
                                        <param name="types" value="image"/>
                                        <param name="max" value="1"/>
                                    </params>
                                </property>
                                <property name="features" type="block">
                                    <meta>
                                        <title lang="en">Bullet points</title>
                                        <title lang="de">Aufzählungspunkte</title>
                                    </meta>
                                    <types>
                                        <type name="feature">
                                            <properties>
                                                <property name="text" type="text_line"/>
                                            </properties>
                                        </type>
                                    </types>
                                </property>
                                <property name="link" type="page_selection">
                                    <meta>
                                        <title lang="en">Detail Page (Optional)</title>
                                        <title lang="de">Detailseite (Optional)</title>
                                    </meta>
                                </property>
                            </properties>
                        </type>
                    </types>
                </property>
            </properties>
        </section>

        <section name="visit_us">
            <meta>
                <title lang="en">Visit Us</title>
                <title lang="de">Besuchen Sie uns</title>
            </meta>
            <properties>
                <property name="visit_title" type="text_line">
                    <meta>
                        <title lang="en">Title</title>
                        <title lang="de">Titel</title>
                    </meta>
                </property>
                <section name="emergency_box">
                    <meta>
                        <title lang="en">Emergency Box</title>
                        <title lang="de">Notfall-Box</title>
                    </meta>
                    <properties>
                        <property name="emergency_title" type="text_line">
                            <meta>
                                <title lang="en">Emergency Title</title>
                                <title lang="de">Notfall Titel</title>
                            </meta>
                        </property>
                        <property name="emergency_text" type="text_editor">
                            <meta>
                                <title lang="en">Emergency Text</title>
                                <title lang="de">Notfall Text</title>
                            </meta>
                        </property>
                    </properties>
                </section>
            </properties>
        </section>

        <property name="aktuelles_title" type="text_line">
            <meta>
                <title lang="en">Aktuelles Title</title>
                <title lang="de">Aktuelles Titel</title>
            </meta>
        </property>
        <property name="aktuelles_blocks" type="block">
            <meta>
                <title lang="en">News Items</title>
                <title lang="de">Aktuelle Meldungen</title>
            </meta>
            <types>
                <type name="news">
                    <meta>
                        <title lang="en">News Item</title>
                        <title lang="de">Meldung</title>
                    </meta>
                    <properties>
                        <property name="title" type="text_line">
                            <meta>
                                <title lang="en">Title</title>
                                <title lang="de">Titel</title>
                            </meta>
                        </property>
                        <property name="text" type="text_editor">
                            <meta>
                                <title lang="en">Text</title>
                                <title lang="de">Text</title>
                            </meta>
                        </property>
                        <property name="date" type="text_line">
                            <meta>
                                <title lang="en">Date (optional)</title>
                                <title lang="de">Datum (optional)</title>
                            </meta>
                        </property>
                        <property name="icon" type="media_selection">
                            <meta>
                                <title lang="en">Icon</title>
                                <title lang="de">Icon</title>
                            </meta>
                            <params>
                                <param name="types" value="image"/>
                                <param name="max" value="1"/>
                            </params>
                        </property>
                        <property name="news_type" type="single_select">
                            <meta>
                                <title lang="en">Type / Color</title>
                                <title lang="de">Typ / Farbe</title>
                            </meta>
                            <params>
                                <param name="values" type="collection">
                                    <param name="info">
                                        <meta>
                                            <title lang="en">Info (Blue)</title>
                                            <title lang="de">Info (Blau)</title>
                                        </meta>
                                    </param>
                                    <param name="warning">
                                        <meta>
                                            <title lang="en">Warning (Amber/Holiday)</title>
                                            <title lang="de">Warnung (Bernstein/Urlaub)</title>
                                        </meta>
                                    </param>
                                    <param name="success">
                                        <meta>
                                            <title lang="en">Success (Green)</title>
                                            <title lang="de">Erfolg (Grün)</title>
                                        </meta>
                                    </param>
                                </param>
                                <param name="default" value="info"/>
                            </params>
                        </property>
                    </properties>
                </type>
            </types>
        </property>
    </properties>
</template>
