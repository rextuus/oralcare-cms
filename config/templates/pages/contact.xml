<?xml version="1.0" ?>
<template xmlns="http://schemas.sulu.io/template/template"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://schemas.sulu.io/template/template http://schemas.sulu.io/template/template-1.0.xsd">

    <key>contact</key>

    <view>pages/contact</view>
    <controller>Sulu\Content\UserInterface\Controller\Website\ContentController::indexAction</controller>
    <cacheLifetime>86400</cacheLifetime>

    <meta>
        <title lang="en">Contact</title>
        <title lang="de">Kontakt</title>
    </meta>

    <properties>
        <property name="title" type="text_line" mandatory="true">
            <meta>
                <title lang="en">Title</title>
                <title lang="de">Titel</title>
            </meta>
            <params>
                <param name="headline" value="true"/>
            </params>

            <tag name="sulu.rlp.part"/>
        </property>

        <property name="subtitle" type="text_line">
            <meta>
                <title lang="en">Subtitle</title>
                <title lang="de">Untertitel</title>
            </meta>
        </property>

        <property name="url" type="route" mandatory="true">
            <meta>
                <title lang="en">Resourcelocator</title>
                <title lang="de">Adresse</title>
            </meta>

            <tag name="sulu.rlp"/>
            <tag name="sulu.node.navigation"/>
        </property>

        <section name="opening_hours_override">
            <meta>
                <title lang="en">Opening Hours Override</title>
                <title lang="de">Öffnungszeiten Überschreiben</title>
            </meta>
            <properties>
                <property name="hours" type="block">
                    <meta>
                        <title lang="en">Hours (leave empty to use global settings)</title>
                        <title lang="de">Zeiten (leer lassen, um globale Einstellungen zu verwenden)</title>
                    </meta>
                    <types>
                        <type name="entry">
                            <meta>
                                <title lang="en">Entry</title>
                                <title lang="de">Eintrag</title>
                            </meta>
                            <properties>
                                <property name="days" type="text_line">
                                    <meta>
                                        <title lang="en">Days (e.g. Mon - Fri)</title>
                                        <title lang="de">Tage (z.B. Mo - Fr)</title>
                                    </meta>
                                </property>
                                <property name="time" type="text_line">
                                    <meta>
                                        <title lang="en">Time (e.g. 08:00 - 18:00)</title>
                                        <title lang="de">Zeit (z.B. 08:00 - 18:00)</title>
                                    </meta>
                                </property>
                            </properties>
                        </type>
                    </types>
                </property>
            </properties>
        </section>

        <section name="faqs">
            <meta>
                <title lang="en">Common Questions (FAQs)</title>
                <title lang="de">Häufige Fragen (FAQs)</title>
            </meta>
            <properties>
                <property name="questions" type="block">
                    <meta>
                        <title lang="en">Questions</title>
                        <title lang="de">Fragen</title>
                    </meta>
                    <types>
                        <type name="question_answer">
                            <meta>
                                <title lang="en">Question &amp; Answer</title>
                                <title lang="de">Frage &amp; Antwort</title>
                            </meta>
                            <properties>
                                <property name="question" type="text_line">
                                    <meta>
                                        <title lang="en">Question</title>
                                        <title lang="de">Frage</title>
                                    </meta>
                                </property>
                                <property name="answer" type="text_editor">
                                    <meta>
                                        <title lang="en">Answer</title>
                                        <title lang="de">Antwort</title>
                                    </meta>
                                </property>
                            </properties>
                        </type>
                    </types>
                </property>
            </properties>
        </section>

        <section name="additional_info">
            <meta>
                <title lang="en">Additional Information</title>
                <title lang="de">Zusätzliche Informationen</title>
            </meta>
            <properties>
                <property name="booking_link" type="single_page_selection">
                    <meta>
                        <title lang="en">Booking Page (Termin buchen)</title>
                        <title lang="de">Buchungsseite (Termin buchen)</title>
                    </meta>
                </property>
                <property name="emergency_info" type="text_editor">
                    <meta>
                        <title lang="en">Emergency Care Info</title>
                        <title lang="de">Notfallversorgung Info</title>
                    </meta>
                </property>
                <property name="languages_info" type="text_editor">
                    <meta>
                        <title lang="en">Languages Spoken Info</title>
                        <title lang="de">Gesprochene Sprachen Info</title>
                    </meta>
                </property>
            </properties>
        </section>

    </properties>
</template>
