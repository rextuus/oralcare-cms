<?xml version="1.0" ?>
<template xmlns="http://schemas.sulu.io/template/template"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://schemas.sulu.io/template/template http://schemas.sulu.io/template/template-1.0.xsd">

    <key>footer_settings</key>

    <meta>
        <title lang="en">Footer Settings</title>
        <title lang="de">Footer-Einstellungen</title>
    </meta>

    <properties>
        <property name="title" type="text_line" mandatory="true">
            <meta>
                <title lang="en">Title</title>
                <title lang="de">Titel</title>
            </meta>
            <tag name="sulu.node.name"/>
        </property>

        <section name="general_info">
            <meta>
                <title lang="en">General Information</title>
                <title lang="de">Allgemeine Informationen</title>
            </meta>
            <properties>
                <property name="footer_info_text" type="text_editor">
                    <meta>
                        <title lang="en">Footer Info Text</title>
                        <title lang="de">Footer Info Text</title>
                    </meta>
                </property>
            </properties>
        </section>


        <section name="services">
            <meta>
                <title lang="en">Top Services (Footer)</title>
                <title lang="de">Top-Leistungen (Footer)</title>
            </meta>
            <properties>
                <property name="top_services" type="block" default-type="service">
                    <meta>
                        <title lang="en">Services</title>
                        <title lang="de">Leistungen</title>
                    </meta>
                    <types>
                        <type name="service">
                            <meta>
                                <title lang="en">Service</title>
                                <title lang="de">Leistung</title>
                            </meta>
                            <properties>
                                <property name="title" type="text_line">
                                    <meta>
                                        <title lang="en">Title</title>
                                        <title lang="de">Titel</title>
                                    </meta>
                                </property>
                                <property name="link" type="page_selection">
                                    <meta>
                                        <title lang="en">Link</title>
                                        <title lang="de">Link</title>
                                    </meta>
                                    <params>
                                        <param name="max" value="1"/>
                                    </params>
                                </property>
                            </properties>
                        </type>
                    </types>
                </property>
            </properties>
        </section>

        <section name="quick_links_section">
            <meta>
                <title lang="en">Quick Links (Footer)</title>
                <title lang="de">Schnellzugriff (Footer)</title>
            </meta>
            <properties>
                <property name="quick_links_context" type="single_select">
                    <meta>
                        <title lang="en">Navigation Context</title>
                        <title lang="de">Navigationskontext</title>
                    </meta>
                    <params>
                        <param name="values" type="collection">
                            <param name="main">
                                <meta>
                                    <title lang="en">Main Navigation</title>
                                    <title lang="de">Hauptnavigation</title>
                                </meta>
                            </param>
                            <param name="footer">
                                <meta>
                                    <title lang="en">Footer Navigation</title>
                                    <title lang="de">Footer-Navigation</title>
                                </meta>
                            </param>
                        </param>
                        <param name="default" value="footer"/>
                    </params>
                </property>

                <property name="quick_links_custom" type="page_selection">
                    <meta>
                        <title lang="en">Custom Selection (Overrides Context)</title>
                        <title lang="de">Benutzerdefinierte Auswahl (Überschreibt Kontext)</title>
                    </meta>
                </property>
            </properties>
        </section>
    </properties>

    <areas>
        <area key="footer_settings" cache-invalidation="true">
            <meta>
                <title lang="en">Footer Settings</title>
                <title lang="de">Footer-Einstellungen</title>
            </meta>
        </area>
    </areas>

</template>
