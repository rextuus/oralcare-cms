<?xml version="1.0" ?>
<template xmlns="http://schemas.sulu.io/template/template"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://schemas.sulu.io/template/template http://schemas.sulu.io/template/template-1.0.xsd">

    <key>footer_settings</key>

    <meta>
        <title lang="en">Footer Settings</title>
        <title lang="de">Footer-Einstellungen</title>
    </meta>

    <properties>
        <property name="title" type="text_line" mandatory="true">
            <meta>
                <title lang="en">Title</title>
                <title lang="de">Titel</title>
            </meta>
            <tag name="sulu.node.name"/>
        </property>

        <section name="contact_info">
            <meta>
                <title lang="en">Contact Information</title>
                <title lang="de">Kontaktinformationen</title>
            </meta>
            <properties>
                <property name="address" type="text_area">
                    <meta>
                        <title lang="en">Address</title>
                        <title lang="de">Adresse</title>
                    </meta>
                </property>
                <property name="phone" type="text_line">
                    <meta>
                        <title lang="en">Phone</title>
                        <title lang="de">Telefon</title>
                    </meta>
                </property>
                <property name="email" type="text_line">
                    <meta>
                        <title lang="en">Email</title>
                        <title lang="de">E-Mail</title>
                    </meta>
                </property>
            </properties>
        </section>

        <section name="services">
            <meta>
                <title lang="en">Top Services (Footer)</title>
                <title lang="de">Top-Leistungen (Footer)</title>
            </meta>
            <properties>
                <property name="top_services" type="block" default-type="service">
                    <meta>
                        <title lang="en">Services</title>
                        <title lang="de">Leistungen</title>
                    </meta>
                    <types>
                        <type name="service">
                            <meta>
                                <title lang="en">Service</title>
                                <title lang="de">Leistung</title>
                            </meta>
                            <properties>
                                <property name="title" type="text_line">
                                    <meta>
                                        <title lang="en">Title</title>
                                        <title lang="de">Titel</title>
                                    </meta>
                                </property>
                                <property name="link" type="page_selection">
                                    <meta>
                                        <title lang="en">Link</title>
                                        <title lang="de">Link</title>
                                    </meta>
                                    <params>
                                        <param name="max" value="1"/>
                                    </params>
                                </property>
                            </properties>
                        </type>
                    </types>
                </property>
            </properties>
        </section>
    </properties>

    <areas>
        <area key="footer_settings" cache-invalidation="true">
            <meta>
                <title lang="en">Footer Settings</title>
                <title lang="de">Footer-Einstellungen</title>
            </meta>
        </area>
    </areas>

</template>
